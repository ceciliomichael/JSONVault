# JSONVault Core API base URL. Used only by the UI server.
JSONVAULT_API_BASE_URL=http://localhost:5766

# Core-compatible JWT signing secret. Must match Core. The UI server uses this
# to mint short-lived, server-only project manager tokens for dashboard
# operations. Never expose this to browser code.
JSONVAULT_JWT_SECRET=

# UI-only HTTP-only cookie signing secret. Use a long random value.
JSONVAULT_DASHBOARD_SESSION_SECRET=

# Core Bearer token used by the UI server for dashboard metadata records.
# Default model: project_admin scoped to JSONVAULT_DASHBOARD_AUTH_DATABASE.
JSONVAULT_API_KEY=

# Core storage for dashboard user records.
JSONVAULT_DASHBOARD_AUTH_DATABASE=jsonvault_dashboard
JSONVAULT_DASHBOARD_AUTH_COLLECTION=dashboard_users

# Core storage for dashboard project records. Defaults to the dashboard auth
# database and dashboard_projects collection.
JSONVAULT_DASHBOARD_PROJECTS_DATABASE=jsonvault_dashboard
JSONVAULT_DASHBOARD_PROJECTS_COLLECTION=dashboard_projects

# Core storage for dashboard-owned API key metadata. Stores token prefixes and
# metadata only, never full generated tokens.
JSONVAULT_DASHBOARD_API_KEYS_DATABASE=jsonvault_dashboard
JSONVAULT_DASHBOARD_API_KEYS_COLLECTION=dashboard_api_keys
