# ==========================================
# JSONVault Configuration
# ==========================================

# ------------------------------------------
# Authentication & Security
# ------------------------------------------

# Comma-separated list of API keys with optional Role-Based Access Control (RBAC) scopes.
# Scopes:
#   - admin (default): Full access to everything, including deleting databases and backups.
#   - read_write: Can create/update/delete documents and collections, but cannot delete databases or backup.
#   - read_only: Can only execute GET requests.
# Format: <key>:<scope>,<key>:<scope>
JSONVAULT_API_KEYS=secret_admin_key:admin,secret_app_key:read_write,secret_viewer_key:read_only

# Optional: At-Rest Encryption (AES-GCM).
# If provided, all new/updated documents will be encrypted before being written to disk.
# MUST be exactly 64 hex characters (32 bytes).
# Example generated via: openssl rand -hex 32
# JSONVAULT_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ------------------------------------------
# Server & Network
# ------------------------------------------

# Address to listen on (default is :8080)
JSONVAULT_ADDR=:8080

# The base URL used by clients to reach this server. 
JSONVAULT_BASE_URL=http://localhost:8080

# Maximum size of an HTTP request body in bytes (default 10MB = 10485760).
JSONVAULT_MAX_BODY_BYTES=10485760

# ------------------------------------------
# Storage & Performance
# ------------------------------------------

# The directory where .db files will be stored.
JSONVAULT_DATA_DIR=./data

# Maximum number of database files to keep open concurrently.
# Higher = more memory usage but fewer disk I/O operations when switching databases.
JSONVAULT_CACHE_ENTRIES=10

# ------------------------------------------
# Timeouts (Go Duration Strings)
# ------------------------------------------

# Time allowed to read the entire request, including the body.
JSONVAULT_READ_TIMEOUT=15s

# Time allowed to read the request headers.
JSONVAULT_READ_HEADER_TIMEOUT=5s

# Time allowed to write the response.
JSONVAULT_WRITE_TIMEOUT=15s

# Maximum amount of time to wait for the next request when keep-alives are enabled.
JSONVAULT_IDLE_TIMEOUT=60s

# Time allowed for the server to gracefully drain active requests before shutting down.
JSONVAULT_SHUTDOWN_TIMEOUT=10s
