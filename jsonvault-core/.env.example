# ==========================================
# JSONVault Configuration
# ==========================================

# ------------------------------------------
# Authentication & Security
# ------------------------------------------

# The master admin key used to manage databases and generate scoped JWT API keys.
JSONVAULT_ADMIN_KEY=super_secret_admin_password

# The secret used to cryptographically sign generated Collection-Level API Keys (JWTs).
# MUST be a long, random string.
JSONVAULT_JWT_SECRET=super_secret_signing_key

# Optional: At-Rest Encryption (AES-GCM).
# If provided, all new/updated documents will be encrypted before being written to disk.
# MUST be exactly 64 hex characters (32 bytes).
# Example generated via: openssl rand -hex 32
# JSONVAULT_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Optional: fail startup unless a valid encryption key is configured, and reject
# legacy plaintext documents until they are migrated.
# JSONVAULT_ENCRYPTION_REQUIRED=true

# Optional: Disable Server-Side Request Forgery (SSRF) Protection for Webhooks.
# By default, JSONVault blocks webhooks targeting localhost or private IPs.
# Set this to true ONLY for local testing or if you explicitly want to allow it.
# JSONVAULT_ALLOW_LOCAL_WEBHOOKS=true

# ------------------------------------------
# Server & Network
# ------------------------------------------

# Address to listen on.
# If unset, the built-in default is :8080; this template uses :5766.
JSONVAULT_ADDR=:5766

# Maximum size of an HTTP request body in bytes (default 10MB = 10485760).
JSONVAULT_MAX_BODY_BYTES=10485760

# Maximum HTTP header size in bytes.
JSONVAULT_MAX_HEADER_BYTES=1048576

# Maximum admin/operational requests per bearer token or client IP per minute.
JSONVAULT_ADMIN_RATE_LIMIT_PER_MINUTE=120

# Optional local diagnostics. Leave empty in production unless bound to localhost.
# JSONVAULT_PPROF_ADDR=127.0.0.1:6060

# ------------------------------------------
# Storage & Performance
# ------------------------------------------

# Server/operator profile. This is for the person hosting JSONVault, not for
# application users connecting to the hosted database.
# tiny: small home/VPS devices around 0.5 vCPU / 1GB RAM. Lower memory,
#       response, query scan, and backup concurrency defaults.
# default: balanced defaults for normal self-hosted/small production servers.
# large: higher limits for larger servers after you have tested your workload.
JSONVAULT_PROFILE=default

# The directory where .db files will be stored.
JSONVAULT_DATA_DIR=./data

# Maximum number of database files to keep open concurrently.
# Higher = more memory usage but fewer disk I/O operations when switching databases.
JSONVAULT_CACHE_ENTRIES=10

# Maximum normalized JSON document size stored by the core engine.
JSONVAULT_MAX_DOCUMENT_BYTES=10485760

# Maximum approximate bytes returned by one list query.
JSONVAULT_MAX_RESPONSE_BYTES=33554432

# Maximum documents/bytes a list query may scan before being rejected.
JSONVAULT_MAX_QUERY_SCAN_DOCS=50000
JSONVAULT_MAX_QUERY_SCAN_BYTES=134217728
JSONVAULT_MAX_QUERY_DURATION=15s

# Backup snapshots are written here before streaming to the client.
# Defaults to JSONVAULT_DATA_DIR/_tmp/backups when empty.
# JSONVAULT_BACKUP_TEMP_DIR=./data/_tmp/backups

# Maximum concurrent backup snapshots.
JSONVAULT_BACKUP_CONCURRENCY=1

# ------------------------------------------
# Timeouts (Go Duration Strings)
# ------------------------------------------

# Time allowed to read the entire request, including the body.
JSONVAULT_READ_TIMEOUT=15s

# Time allowed to read the request headers.
JSONVAULT_READ_HEADER_TIMEOUT=5s

# Time allowed to write the response.
JSONVAULT_WRITE_TIMEOUT=15s

# Maximum amount of time to wait for the next request when keep-alives are enabled.
JSONVAULT_IDLE_TIMEOUT=60s

# Time allowed for the server to gracefully drain active requests before shutting down.
JSONVAULT_SHUTDOWN_TIMEOUT=10s
